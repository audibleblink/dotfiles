{
  "$schema": "https://opencode.ai/tui.json",
  "theme": "catppuccin",
  "keybinds": {
    // remove ctrl+d from default
    "app_exit": "ctrl+c,<leader>q",
    "input_delete": "delete,shift+delete",
    // --------------------------
	"command_list": "alt+p",
    "messages_half_page_down": "ctrl+u",
    "messages_half_page_up": "ctrl+d",
	"messages_next": "ctrl+n",
    "messages_previous": "ctrl+p"
  }
}

{
	"$schema": "https://opencode.ai/config.json",
	"model": "anthropic/claude-sonnet-4-6",
	"small_model": "anthropic/claude-haiku-4-5",
	"disabled_providers": ["openai", "gemini"],

	"provider": {
		"azure-foundry-claude": {
			"npm": "@ai-sdk/anthropic",
			"name": "Azure Anthropic",
			"options": {
				"baseURL": "{env:AZURE_FOUNDRY_HOST}/anthropic/v1",
				"apiKey": "{env:AZURE_FOUNDRY_CLAUDE_KEY}",
				"headers": {
					"anthropic-version": "2023-06-01"
				}
			},
			"models": {
				"claude-opus-4-5": {
					"name": "Opus 4.5"
				},
				"claude-sonnet-4-5": {
					"name": "Sonnet 4.5"
				},
				"claude-haiku-4-5": {
					"name": "Haiku 4.5"
				}
			}
		},

		"azure-foundry-openai": {
			"npm": "@ai-sdk/azure",
			"name": "Azure OpenAI",
			"options": {
				"resourceName": "rule10",
				"apiKey": "{env:AZURE_FOUNDRY_OPENAI_KEY}"
			},
			"models": {
				"rule10-gpt-5-2": {
					"name": "gpt-5.2"
				}
			}
		},

		"walthropic": {
			"npm": "@ai-sdk/anthropic",
			"name": "Walthropic",
			"options": {
				"baseURL": "http://localhost:8888/v1",
				"apiKey": "hunter2"
			},
			"models": {
				"claude-sonnet-4-5": {
					"name": "Claude Sonnet 4.5"
				},
				"claude-sonnet-4-6": {
					"name": "Claude Sonnet 4.6"
				},
				"claude-opus-4-5": {
					"name": "Claude Opus 4.5"
				},
				"claude-opus-4-6": {
					"name": "Claude Opus 4.6"
				},
				"claude-haiku-4-5": {
					"name": "Claude Haiku"
				}
			}
		}
	}
}
